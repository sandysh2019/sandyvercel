# Frontend
# Dev: http://localhost:3001/api
# Prod: https://your-api-domain.com/api
VITE_API_URL=http://localhost:3001/api

# Backend
PORT=3001
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=http://localhost:5173

# Admin bootstrap (first run only if database is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Optional SMTP (enable contact email automation later)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional future MongoDB migration
# Set USE_MONGODB=true to enable MongoDB.
# If false, JSON file DB will be used at data/database.json.
USE_MONGODB=false
MONGODB_DB_NAME=portfolio_cms
MONGODB_URI=
